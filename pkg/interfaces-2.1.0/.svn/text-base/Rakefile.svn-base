require 'rubygems'
require 'rake'
require 'rake/clean'
require 'rake/gempackagetask'
require 'rake/rdoctask'
require 'rake/testtask'

spec = Gem::Specification.new do |s|
  s.name = 'interfaces'
  s.version = '2.1.0'
  s.has_rdoc = true
  s.extra_rdoc_files = ['README', 'LICENSE']
  s.summary = 'Framework for configuring file interfaces'
  s.description = <<-EOF
    Defines abstract sources and sinks to put resp. to get files.
    Contains implementations for directory, ftp, sftp and mail.
    Defines abstract filters for files.
    Contains implementations for zip and pgp.
  EOF

  s.author = 'Thomas Sonntag'
  s.email = 'thomas@sonntagsbox.de'
  # s.executables = ['your_executable_here']
  s.files = %w(LICENSE README Rakefile) + Dir.glob("{bin,lib,spec}/**/*")
  s.require_path = "lib"
  s.bindir = "bin"
  s.add_dependency 'net-sftp', '>= 2.0'
  s.add_dependency 'rubyzip',  '>= 0.9'
  s.add_dependency 'actionmailer',  '>= 3.0'
  s.add_dependency 'activesupport',  '>= 3.0'
  s.add_dependency 'facets',  '>= 2.8'
end

Rake::GemPackageTask.new(spec) do |p|
  p.gem_spec = spec
  p.need_tar = true
  p.need_zip = true
end

Rake::RDocTask.new do |rdoc|
  files =['README', 'LICENSE', 'lib/**/*.rb']
  rdoc.rdoc_files.add(files)
  rdoc.main = "README" # page to start on
  rdoc.title = "interfaces Docs"
  rdoc.rdoc_dir = 'doc/rdoc' # rdoc output folder
  rdoc.options << '--line-numbers'
end

Rake::TestTask.new do |t|
  t.test_files = FileList['test/**/*.rb']
end
